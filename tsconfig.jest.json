{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "types": ["jest", "node"],
    "isolatedModules": true
  },
  "baseUrl": "./",
  "paths": {
    "typescript-cookie": ["node_modules/typescript-cookie"]
  },
  "include": [
    "__tests__/**/*.test.ts",
    "__tests__/**/*.test.tsx",
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/setupTests.ts"
  ]
}